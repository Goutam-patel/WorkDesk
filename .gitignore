# Monorepo-wide ignores

# Dependencies
**/node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Build and coverage outputs
**/dist/
**/build/
**/coverage/
**/.next/
**/out/

# TypeScript / Next.js
**/*.tsbuildinfo
**/next-env.d.ts

# Tooling / cache
**/.cache/
**/.turbo/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/